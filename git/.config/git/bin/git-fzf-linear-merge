#! /bin/bash
# vim: set ft=sh:

set -euxo pipefail

cleanup() {
	tput rmcup
	tput ed || tput cd
}

trap cleanup EXIT

script_name='fzf-linear-merge'
confirm_format=''
confirm_format+="$(git config --get-color color.diff.commit yellow)%h%Creset %C(bold)%s%Creset"
confirm_format+='%n'
confirm_format+='%x09'
# confirm_format+='Author: '
confirm_format+='%aN (%C(italic)%ad%C(reset))%Creset'
# confirm_format+='%n'
# confirm_format+='%x09Committer: %cN (%C(italic)%cd%C(reset))%Creset'

if test "$(uname -s)" == Darwin; then
	# Check for GNU sed -- default sed does not support hex escapes or pcre
	if command -v gsed >/dev/null 2>&1; then
		sed='gsed'
	elif sed --version >/dev/null 2>&1 | grep -iq 'GNU sed'; then
		sed='sed'
	else
		echo 'Unsupported version of sed' >&2
		exit 3
	fi
	if command -v ggrep >/dev/null 2>&1; then
		grep='ggrep'
	elif grep --version >/dev/null 2>&1 | grep -iq 'GNU grep'; then
		grep='grep'
	else
		echo 'Unsupported version of grep' >&2
		exit 3
	fi
fi

fzf=(fzf --ansi --reverse --height 40%)

selector() {
	"${fzf[@]}" "$@"
	return $?
}

# XXX: This is hot-path code, look into some sort of LRU cache
check-linear() {
	base="$1"
	other="$(git rev-parse -q --verify "$2")" || return 1
	git rev-parse -q --verify "$base" >/dev/null 2>&1 || return 1

	git merge-base --is-ancestor "$base" "$other"
	return $?
}

find-children() {
	base="$1"
	base_commit="$(git rev-parse --verify "$1")"

	# git show-ref --heads \
	# | "$grep" -Eo 'refs/heads/.+' \
	# | cut -d'/' -f 3- \
	git show-ref --heads \
	| "$grep" -Po '(?<=refs/heads/).+$' \
	| while read -r branch; do
		if test "$branch" != "$base" && check-linear "$base_commit" "$branch"; then
			echo "$branch"
		fi
	done
}

list-linear() {
	base="$1"
	other="$2"
	check-linear "$base" "$other" || return 1

	git log --color=always --pretty=oneline --decorate=short --abbrev-commit "$base~1..$other"
}

select-linear() {
	base="$1"
	other="$2"
	check-linear "$base" "$other" || return 1

	list-linear "$base" "$other" | selector --tac --prompt='commit> ' +s | cut -d' ' -f 1
}

select-branch() {
	if test $# -eq 0; then
		args=(--prompt 'branch> ')
	else
		args=("$@")
	fi

	git branch --color=always | selector "${args[@]}"
}

fast-forward() {
	base="$1"
	other="$2"
	check-linear "$base" "$other" || return 1
	
	msg="$script_name: moving $base to $(git rev-parse --short "$other")" 
	git update-ref -m "$msg" --create-reflog "refs/heads/$base" "$other"
	git update-index --refresh >/dev/null
    # git read-tree -m -u --exclude-per-directory=.gitignore HEAD "$other"
}

if test "$(git branch --list | wc -l)" -lt 2; then
	exit 1
fi

list_branches=(git branch --color=always)
escape_pattern='\x1B\[([0-9]{1,2}(;[0-9]{1,2})?)?m'

if test $# -lt 1; then
	if ! \
		read -r base < <(
			"${list_branches[@]}" \
			| selector --prompt 'branch (base)> ' --no-clear \
			| "$sed" -E 's/^[ *]+//' \
		) \
	; then
		exit 2
	fi
	if test -z "$base"; then
		exit 1
	fi
else
	base="$1"
fi

# cat >/dev/null <<"EOF"
if test $# -lt 2; then
	list_branches+=()
	if ! \
		read -r other < <(
			find-children "$base" \
			| xargs git branch --list \
			| "$grep" -Ev "^\*? *($escape_pattern)?$base($escape_pattern)?$" \
			| selector --prompt 'branch (other)> ' --no-clear \
			| "$sed" -E 's/^[ *]+//' \
		) \
	; then
		exit 2
	fi
	if test -z "$base"; then
		exit 1
	fi
else
	other="$2"
fi

branch_head="$(select-linear "$base" "$other")" || exit 2

if test -z "$branch_head"; then
	exit 2
fi
if test "$(git rev-parse -q --verify "$base")" = "$(git rev-parse -q --verify "$branch_head")"; then
	echo 'ERROR: Selected commit is in branch.' >&2
	exit 1
fi

# TODO: Add confirmation
# git --no-pager show --pretty="$confirm_format" --date=short --no-patch "$base~..$branch_head"
git --no-pager show --oneline --no-patch "$base~..$branch_head"

fast-forward "$base" "$branch_head" || exit 5
# EOF
