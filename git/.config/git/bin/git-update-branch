#! /usr/bin/env bash

# Update one $branch to target another branch or arbitrary git ref.
#
# If the target is HEAD and HEAD is detached, this script additionally runs
# `git checkout $branch`.
#
# To test this script, run the following on a less-important repository
# (assuming main's already checked out):
#
#     git checkout main
#     git update-branch tmp-test-git-update-branch HEAD~1
#     git checkout "$(git rev-parse --verify HEAD)"
#     git branchless smartlog
#     git update-branch tmp-test-git-update-branch HEAD
#     git branchless smartlog
#     git checkout main

set -euo pipefail

test -n "${DEBUG:-}" && set -x

if test $# -lt 2; then
	exit 1
fi

if ! existing_rev="$(git rev-parse "$1^{commit}" 2>/dev/null)"; then
	existing_rev=''
fi
new_rev="$(git rev-parse "$2^{commit}" 2>/dev/null)"

if test "$2" = "$new_rev"; then
	new_rev_msg="$2"
else
	new_rev_msg="[$2]($new_rev)"
fi

targets_head=
if test "$new_rev" = "$(git rev-parse --verify 'HEAD^{commit}')"; then
	targets_head=1
fi

on_detached_head=
if ! git symbolic-ref -q HEAD >/dev/null; then
	on_detached_head=1
fi

target_ref="refs/heads/$1"

cmd=(git update-ref --create-reflog)

case $# in
	2)
		message="git-update-branch: Updating branch [$1] to $new_rev_msg"
		if test -n "$existing_rev"; then
			message="$message from [$existing_rev]"
		fi
		cmd+=(-m "$message" "$target_ref" "$2")
		if git rev-parse --verify --end-of-options "$1^{commit}" 2>/dev/null; then
			cmd+=("$existing_rev")
		fi
		;;
	3)
		cmd+=(-m "git-update-branch: Updating branch [$1] to $new_rev_msg from [$3]" "$target_ref" "$2" "$3")
		;;
esac

echo "${cmd[@]@Q}"
"${cmd[@]}"

if test -n "$targets_head" && test -n "$on_detached_head"; then
	git checkout "$1"
fi
